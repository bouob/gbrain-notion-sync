# Notion API token — obtain from https://notion.so/my-integrations
NOTION_TOKEN=secret_YOUR_TOKEN_HERE

# ---------------------------------------------------------------------------
# Notion Database IDs — obtain from each database's Notion page URL.
#
# In Notion, open the database as a full page. The URL looks like:
#   https://www.notion.so/<workspace>/<page-title>-<32-char-uuid>?v=...
# The 32-char UUID (insert hyphens to form 8-4-4-4-12) is the Database ID.
#
# Each user must use THEIR OWN PAI workspace's database IDs.
# These four databases must be shared with the Notion integration
# (Notion UI: database page > ... > Connections > Add gbrain-sync).
# ---------------------------------------------------------------------------
NOTION_DB_PROJECTS=
NOTION_DB_TODO=
NOTION_DB_INBOX=
NOTION_DB_KNOWLEDGE=

# ---------------------------------------------------------------------------
# gbrain HTTP Server (Lock-Free Sync Mode) — optional but recommended
#
# When set, sync write operations (putPage / putRawPage / deletePage) route
# through the gbrain HTTP MCP server instead of the CLI.
# This eliminates the PGLite single-writer lock conflict that occurs when
# `gbrain serve` (Claude Code MCP) is running alongside the sync script.
#
# Setup: see RUNBOOK.md § HTTP Server Mode (Lock-Free Sync)
#   GBRAIN_HTTP_URL  = server root, NO /mcp suffix
#   GBRAIN_HTTP_TOKEN = OAuth access_token (NOT a gbrain_cs_ client_secret)
# ---------------------------------------------------------------------------
# GBRAIN_HTTP_URL=http://localhost:7432
# GBRAIN_HTTP_TOKEN=
